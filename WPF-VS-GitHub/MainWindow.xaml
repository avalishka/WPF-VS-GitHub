<Window x:Class="WPF_VS_GitHub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_VS_GitHub"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <Label Content="Введите ваше имя:" FontSize="14"/>
            <TextBox Name="nameTextBox" Width="250" Height="30" Margin="0,5,0,10"/>
            <Button Name="greetButton" Content="Поздороваться" Width="150" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
